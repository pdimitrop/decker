---
// assets
import Github from "../../assets/icons/Github.astro";
import Linkedin from "../../assets/icons/Linkedin.astro";

const socials = [
  { link: "https://github.com/pdimitrop", icon: Github, label: "GitHub" },
  { link: "https://www.linkedin.com/in/pidimitropoulos/", icon: Linkedin, label: "LinkedIn" }
];
---

<div class="flex flex-row gap-24">
  {
    socials.map((social) => {
      const Icon = social.icon;
      return (
        <a
          href={social.link}
          class="text-base-100 hover:text-base-300"
          aria-label={social.label}
          target="_blank"
          rel="noopener noreferrer"
        >
          <Icon width={20} height={20} fill="currentColor" />
        </a>
      );
    })
  }
</div>
